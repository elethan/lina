# ─── Required ────────────────────────────────────────────────────────────────
# Secret used by Better Auth to sign sessions (generate with: openssl rand -hex 32)
# REQUIRED — replace with the output of: openssl rand -hex 32
BETTER_AUTH_SECRET=3df9dc41732e45c560e7305c635923f40862b6c4f218c9c5aaa40330acd74fc3

# ─── Database ─────────────────────────────────────────────────────────────────
# Canonical SQLite file path used by the running app.
# Local default is lina-local.db if this is left unset.
# Docker default is /app/shared-lina-db-vol/lina_prod.db from the Dockerfile,
# so you usually only set this when you want to override that location.
#DB_PATH=lina-local.db

# ─── Microsoft Entra ID SSO (optional) ───────────────────────────────────────
# Leave these unset (or don't create a .env file at all) to disable SSO and
# log in with the built-in email/password admin account instead.
#
# When all three variables below are set, Microsoft SSO is enabled automatically.
# Also set VITE_ENABLE_MICROSOFT_SSO=true so the "Sign in with Microsoft" button
# appears on the login page.
#
# MICROSOFT_CLIENT_ID=your-azure-app-client-id
# MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
# MICROSOFT_TENANT_ID=your-azure-tenant-id
# VITE_ENABLE_MICROSOFT_SSO=true

# ─── Production only ──────────────────────────────────────────────────────────
 VITE_APP_URL=https://46.101.53.201

# BETTER_AUTH_URL="http://localhost:3000" # Change this when deployed
 BETTER_AUTH_URL=https://46.101.53.201